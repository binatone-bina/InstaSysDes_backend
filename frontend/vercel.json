{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://connectsphere-backend-6leh.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://connectsphere-backend-6leh.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads).*)*",
      "destination": "/index.html"
    }
  ]
}
